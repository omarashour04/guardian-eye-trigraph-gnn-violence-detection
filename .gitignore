*.npz

# Results, figures, and data artifacts — code-only repo, do not push these
*.csv
# Exception: paper_data CSVs are ground-truth inference results (small, version-controlled)
!paper_data/**/*.csv
*.json
*.png
*.jpg
*.jpeg
*.mp4
*.avi
*.mpeg
*.done

# Kaggle credentials
kaggle.json
.kaggle/

